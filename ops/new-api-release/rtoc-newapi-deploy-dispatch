#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

DEPLOY_COMMAND="${NEWAPI_DEPLOY_COMMAND:-/usr/local/libexec/rtoc-newapi-deploy}"

die() {
    printf 'error: %s\n' "$*" >&2
    exit 64
}

safe_token() {
    [[ "$1" =~ ^[A-Za-z0-9._:@/+%-]+$ ]]
}

original="${SSH_ORIGINAL_COMMAND:-}"
[[ -n "${original}" ]] || die "an explicit deployment command is required"
[[ "${original}" != *$'\n'* && "${original}" != *$'\r'* ]] \
    || die "multiline commands are not allowlisted"

n8n_cwd_prefix="cd / ; "
if [[ "${original}" == "${n8n_cwd_prefix}"* ]]; then
    original="${original#"${n8n_cwd_prefix}"}"
fi

IFS=' ' read -r -a arguments <<<"${original}"
command="${arguments[0]:-}"

case "${command}" in
    status | rollback)
        [[ "${#arguments[@]}" -eq 1 ]] || die "invalid ${command} command"
        ;;
    cutover)
        [[ "${#arguments[@]}" -eq 2 ]] || die "invalid cutover command"
        safe_token "${arguments[1]}" || die "invalid release identifier"
        ;;
    prepare)
        [[ "${#arguments[@]}" -eq 5 ]] || die "invalid prepare command"
        [[ "${arguments[1]}" =~ ^ghcr\.io/hechuyi/new-api-rtoc@sha256:[0-9a-f]{64}$ ]] \
            || die "candidate image must be an immutable allowed digest"
        [[ "${arguments[2]}" =~ ^sha256:[0-9a-f]{64}$ ]] \
            || die "invalid image ID"
        [[ "${arguments[3]}" =~ ^[0-9a-f]{40}$ ]] \
            || die "invalid source revision"
        safe_token "${arguments[4]}" || die "invalid release identifier"
        ;;
    *)
        die "command is not allowlisted"
        ;;
esac

exec "${DEPLOY_COMMAND}" "${arguments[@]}"
